#!/usr/bin/env bash
# bin/shql — ShellQL CLI entry point
#
# Usage: shql [db_path] [-q <sql>] [--query] [table] [databases]
#
# Environment:
#   SHQL_MOCK=1          Use mock adapter (no sqlite3 required)
#   SHELLFRAME_DIR=path  Override path to shellframe checkout

set -uo pipefail

# ── Terminal capability check ─────────────────────────────────────────────────
# Warn early for dumb/missing TERM. Only applies to TUI modes; pipe/query-out
# modes write to stdout and don't need a capable terminal.
case "${1:-}" in
    -q|--porcelain|databases) ;;   # non-TUI flags — skip check
    *)
        case "${TERM:-}" in
            dumb|"")
                printf 'warning: TERM=%s — ShellQL requires a 256-color terminal (xterm-256color or equivalent).\n' \
                    "${TERM:-unset}" >&2
                ;;
        esac
        _shql_cols=$(tput cols 2>/dev/null || printf '0')
        if (( _shql_cols > 0 && _shql_cols < 120 )); then
            printf 'warning: terminal is %d columns wide — ShellQL recommends at least 120 columns.\n' \
                "$_shql_cols" >&2
        fi
        ;;
esac

# Crash diagnostic: set SHQL_DEBUG=1 and run with 2>/tmp/shql-crash.log
# to capture the exact command that crashes.  ERR trap is installed inside
# shellframe_shell when SHQL_DEBUG is set.
export SHQL_DEBUG="${SHQL_DEBUG:-}"

# ── Locate shellframe ─────────────────────────────────────────────────────────

_SHQL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_SHQL_ROOT="$(cd "$_SHQL_BIN_DIR/.." && pwd)"
SHQL_VERSION="$(cat "$_SHQL_ROOT/VERSION" 2>/dev/null || printf 'dev')"
export SHQL_VERSION

if [[ -n "${SHELLFRAME_DIR:-}" ]]; then
    _SHELLFRAME_ENTRY="$SHELLFRAME_DIR/shellframe.sh"
else
    # Default: sibling checkout at ../shellframe relative to this repo
    _SHELLFRAME_ENTRY="$(cd "$_SHQL_ROOT/.." && pwd)/shellframe/shellframe.sh"
fi

if [[ ! -f "$_SHELLFRAME_ENTRY" ]]; then
    printf 'error: shellframe not found at %s\n' "$_SHELLFRAME_ENTRY" >&2
    printf 'Set SHELLFRAME_DIR to the shellframe checkout directory.\n' >&2
    exit 1
fi

source "$_SHELLFRAME_ENTRY"

# ── Load ShellQL modules ──────────────────────────────────────────────────────

source "$_SHQL_ROOT/src/state.sh"
source "$_SHQL_ROOT/src/json.sh"
source "$_SHQL_ROOT/src/config.sh"
source "$_SHQL_ROOT/src/cli.sh"
source "$_SHQL_ROOT/src/connections.sh"

if (( SHQL_MOCK )); then
    source "$_SHQL_ROOT/src/db_mock.sh"
else
    source "$_SHQL_ROOT/src/db.sh"
fi

# Initialise connection registry (real mode only — mock has no metadata DB)
if ! (( SHQL_MOCK )); then
    shql_conn_init || exit $?
    shql_conn_migrate
fi

# theme: after shellframe (SHELLFRAME_* populated), before screens
source "$_SHQL_ROOT/src/theme.sh"
shql_theme_load "${SHQL_THEME:-basic}"

source "$_SHQL_ROOT/src/autocomplete.sh"

# screens (util.sh first — shared helpers; header.sh before welcome/table)
source "$_SHQL_ROOT/src/screens/util.sh"
source "$_SHQL_ROOT/src/screens/header.sh"
source "$_SHQL_ROOT/src/screens/welcome.sh"
source "$_SHQL_ROOT/src/screens/table.sh"
source "$_SHQL_ROOT/src/screens/query.sh"
source "$_SHQL_ROOT/src/screens/inspector.sh"
source "$_SHQL_ROOT/src/screens/dml.sh"
source "$_SHQL_ROOT/src/screens/where.sh"
source "$_SHQL_ROOT/src/screens/sort.sh"
source "$_SHQL_ROOT/src/screens/export.sh"

# ── Argument parsing ──────────────────────────────────────────────────────────

shql_cli_parse "$@" || exit $?

if [[ "$_SHQL_CLI_MODE" == "help" ]]; then
    shql_cli_help
    exit 0
fi

# ── Name resolution ───────────────────────────────────────────────────────────
# If _SHQL_CLI_DB is set but is not an existing path, attempt to resolve it as
# a short name (e.g. "chinook") from the connection registry.
# Skip in mock mode — there is no registry in SHQL_MOCK=1.

if [[ -n "$_SHQL_CLI_DB" && ! -e "$_SHQL_CLI_DB" ]] && ! (( ${SHQL_MOCK:-0} )); then
    shql_conn_load_recent
    _resolved=$(shql_conn_resolve_name "$_SHQL_CLI_DB")
    [[ -n "$_resolved" ]] && _SHQL_CLI_DB="$_resolved"
fi

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "$_SHQL_CLI_MODE" in
    welcome)
        shql_welcome_run
        ;;

    open)
        SHQL_DB_PATH="$_SHQL_CLI_DB"
        if ! (( SHQL_MOCK )); then _shql_db_check_path "$SHQL_DB_PATH" || exit 1; fi
        shql_conn_push "sqlite" "$SHQL_DB_PATH"
        _shql_welcome_init
        shql_browser_init
        shellframe_shell "_shql" "TABLE"
        ;;

    table)
        SHQL_DB_PATH="$_SHQL_CLI_DB"
        SHQL_DB_TABLE="$_SHQL_CLI_TABLE"
        if ! (( SHQL_MOCK )); then _shql_db_check_path "$SHQL_DB_PATH" || exit 1; fi
        shql_conn_push "sqlite" "$SHQL_DB_PATH"
        _shql_welcome_init
        shql_browser_init
        # Pre-open the table as a Data tab
        _shql_tab_open "$_SHQL_CLI_TABLE" "data"
        shellframe_shell "_shql" "TABLE"
        ;;

    query-tui)
        SHQL_DB_PATH="$_SHQL_CLI_DB"
        if ! (( SHQL_MOCK )); then _shql_db_check_path "$SHQL_DB_PATH" || exit 1; fi
        shql_conn_push "sqlite" "$SHQL_DB_PATH"
        _shql_welcome_init
        shql_browser_init
        _shql_tab_open "" "query"
        shellframe_shell "_shql" "TABLE"
        ;;

    query-out|pipe)
        # Path validation delegated to shql_db_query (_shql_db_check_path inside).
        # Record to recent history only on success so invalid paths are never saved.
        # Route sqlite3 errors to /dev/tty when available (project convention: errors to
        # tty, data to stdout). Fall back to stderr (not /dev/null as TUI modes do) so
        # errors remain visible in CI and scripted contexts.
        SHQL_DB_PATH="$_SHQL_CLI_DB"
        _err_tty=/dev/stderr; ( exec 9>/dev/tty ) 2>/dev/null && _err_tty=/dev/tty
        _tsv=$(shql_db_query "$SHQL_DB_PATH" "$_SHQL_CLI_SQL" 2>"$_err_tty")
        _rc=$?
        if [ "$_rc" -ne 0 ]; then
            exit $_rc
        fi
        shql_conn_push "sqlite" "$SHQL_DB_PATH"
        if (( ${_SHQL_CLI_PORCELAIN:-0} )); then
            printf '%s\n' "$_tsv"
        else
            shql_cli_format_table "$_tsv"
        fi
        ;;

    databases)
        _list=$(shql_conn_list | cut -f1-5)
        if (( ${_SHQL_CLI_PORCELAIN:-0} )); then
            printf '%s\n' "$_list"
        else
            _header=$'source\tdriver\tname\tdetail\tlast_used'
            shql_cli_format_table "${_header}"$'\n'"${_list}"
        fi
        ;;
esac
